# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Your Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key...

# ── Wasabi S3 ─────────────────────────────────────────────────────────────────
# Get these from: https://console.wasabisys.com → Access Keys
WASABI_ACCESS_KEY_ID=your-wasabi-access-key-id
WASABI_SECRET_ACCESS_KEY=your-wasabi-secret-access-key

# Bucket name — must match the bucket you create in Wasabi
WASABI_BUCKET=eastape-share

# Region & endpoint — see table below for all regions:
# us-east-1     → https://s3.us-east-1.wasabisys.com
# us-east-2     → https://s3.us-east-2.wasabisys.com
# us-west-1     → https://s3.us-west-1.wasabisys.com
# eu-central-1  → https://s3.eu-central-1.wasabisys.com
# eu-west-1     → https://s3.eu-west-1.wasabisys.com
# ap-northeast-1 → https://s3.ap-northeast-1.wasabisys.com
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Your deployed Vercel domain — used for CORS.
# During development leave it empty or use http://localhost:5173
FRONTEND_URL=https://your-app.vercel.app

# ── Vite (frontend only — MUST be prefixed VITE_) ─────────────────────────────
# Leave empty when frontend & API are on the same Vercel domain.
# Only set this if you split into two separate projects.
VITE_API_BASE=
